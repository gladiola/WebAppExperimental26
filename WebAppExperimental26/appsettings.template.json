{
  "_TemplateMetadata": {
    "Version": "1.0",
    "Description": "Template configuration for ASP.NET Core 9 Razor Pages project with Azure integration",
    "LastUpdated": "2024-12-20",
    "Instructions": [
      "1. Copy this file to appsettings.json",
      "2. Replace all {{PLACEHOLDER}} values with your actual configuration",
      "3. Store secrets in User Secrets (dotnet user-secrets set <key> <value>)",
      "4. Enable/disable features via FeatureFlags section",
      "5. NEVER commit secrets to source control"
    ],
    "RequiredSecrets": [
      "AzureAd:ClientSecret",
      "AzureAD:ClientCredentials:0:ClientSecret",
      "AzureKeyVault:KeyVaultSecret",
      "BlobSettings:BlobConnectionString",
      "CosmosDb:CosmosConnectionString",
      "CosmosDb:AccountKey"
    ],
    "OptionalSecrets": [
      "NonceEncryption:Key",
      "NonceEncryption:IV",
      "Logging:PiiHmacKey"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "_PiiHmacKey_Instructions": "Generate a 32-byte key with: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 })). Store in User Secrets, not in source control.",
    "PiiHmacKey": "{{OPTIONAL_32_BYTE_BASE64_KEY}}"
  },
  
  "AllowedHosts": "*",

  "FeatureFlags": {
    "EnableSession": true,
    "EnableLocalization": true,
    "EnableAzureAd": false,
    "EnableAuthorization": false,
    "EnableKeyVault": true,
    "EnableNonceServices": false,
    "EnableBlobStorage": false,
    "EnableCosmosDb": false,
    "EnableSecurityHeaders": true,
    "EnableCSP": false,
    "EnableMtls": true,
    "EnableOcspValidation": false
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "{{YOUR_TENANT_DOMAIN}}.onmicrosoft.com",
    "TenantId": "{{YOUR_TENANT_ID}}",
    "ClientId": "{{YOUR_CLIENT_ID}}",
    "ClientSecret": "{{STORE_IN_USER_SECRETS}}",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },

  "AzureAD": {
    "Instance": "https://login.microsoftonline.com/",
    "Authority": "https://login.microsoftonline.com/{{YOUR_TENANT_ID}}",
    "Domain": "{{YOUR_TENANT_DOMAIN}}.onmicrosoft.com",
    "TenantId": "{{YOUR_TENANT_ID}}",
    "ClientId": "{{YOUR_CLIENT_ID}}",
    "CallbackPath": "/signin-oidc",
    "ClientCredentials": [
      {
        "SourceType": "ClientSecret",
        "ClientSecret": "{{STORE_IN_USER_SECRETS}}"
      }
    ]
  },

  "AzureKeyVault": {
    "KeyVaultURL": "https://{{YOUR_KEYVAULT_NAME}}.vault.azure.net/",
    "KeyVaultSecret": "{{STORE_IN_USER_SECRETS}}",
    "KeyVaultPassName": "{{YOUR_CERTIFICATE_NAME}}"
  },

  "NonceEncryption": {
    "_Instructions": "Generate using: .\\SupportingScripts\\IVandKeySampleGenerator.ps1",
    "Key": "{{GENERATE_32_BYTE_BASE64_KEY}}",
    "IV": "{{GENERATE_16_BYTE_BASE64_IV}}"
  },

  "CSPScriptHashes": {
    "_Instructions": "Use HashInlineScriptPowerShell.ps1 to generate hashes for inline scripts",
    "ManuallyCalculatedInlineHash1": "",
    "HashFilePath": "wwwroot/csp-hashes.txt"
  },

  "BlobSettings": {
    "BlobConnectionString": "{{STORE_IN_USER_SECRETS}}",
    "MaxAttachments": 10
  },

  "CosmosDb": {
    "AccountEndpoint": "https://{{YOUR_COSMOSDB_ACCOUNT}}.documents.azure.com:443/",
    "AccountKey": "{{STORE_IN_USER_SECRETS}}",
    "DatabaseName": "{{YOUR_DATABASE_NAME}}",
    "ContainerName": "{{YOUR_CONTAINER_NAME}}",
    "CosmosConnectionString": "{{STORE_IN_USER_SECRETS}}"
  },

  "MtlsSettings": {
    "_Instructions": "Configure mutual TLS (mTLS) client certificate authentication. Server certificate is retrieved from Azure Key Vault.",
    "RequireClientCertificate": true,
    "AllowCertificateChains": true,
    "AllowSelfSignedCertificates": false,
    "CheckCertificateRevocation": false,
    "ClientCertificateName": "{{YOUR_CLIENT_CERT_NAME_IN_KEYVAULT}}",
    "ValidateClientCertificateIssuer": true
  },

  "OcspSettings": {
    "_Instructions": "Configure OCSP (Online Certificate Status Protocol) for real-time certificate validation. OCSP server must be implemented separately.",
    "EnableOcspValidation": false,
    "OcspServerUrl": "{{YOUR_OCSP_SERVER_URL}}",
    "RequestTimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "CacheDurationMinutes": 60,
    "ServerUnavailableBehavior": "Warn",
    "EnableDetailedLogging": false,
    "SkipValidationInDevelopment": true
  }
}
