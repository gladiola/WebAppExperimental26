@page
@model REDRFID.Pages.Red.FileUploads.BasicCSVUploaderModel
@{

    /*
     *  
     *  Under this scheme for a CSV, we would need to provide input for 
     *  the following fields for each record provided in order to keep the
     *  searches and inputs stable and uniform. 
     * 
     *  public int Id { get; set; } = 0;
        public string UploadedUser { get; set; } = String.Empty;
        public string UserID { get; set;} = String.Empty;
        public string? IdString { get; set; } = String.Empty;
        public string _partitionKey { get; set; } = String.Empty;

     */





}


<h2>RED Basic CSV Uploader</h2>
<p>Provide a CSV file with the following column names to add RED Record objects in bulk:</p>


<ul>
    <li>FacilityCode</li>
    <li>CardNumber</li>
    <li>ParityBits</li>
    <li>LocationAddress</li>
    <li>LocationCity</li>
    <li>LocationState</li>
    <li>LocationZip</li>
    <li>LocationLat</li>
    <li>LocationLong</li>
    <li>RfidRisk</li>
    <li>CompanyName</li>
    <li>RFIDContent</li>
</ul>


<form method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="CsvDataIn"></label>
        <input type="file" asp-for="CsvDataIn" class="form-control" />
        <span asp-validation-for="CsvDataIn" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Upload</button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary()
        </div>
    }
</form>
