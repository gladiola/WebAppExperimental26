@page
@model REDRFID.Pages.Red.SearchBy.CompanyNameModel
@using REDRFID.Models.Storage
@{
    ViewData["Title"] = "Search By Company Name";
}

<h1>Search By Company Name</h1>

<div class="col-md-4">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
 
        <div class="form-group">

            <label asp-for="CompanyName" class="control-label"></label>
            <input asp-for="CompanyName" class="form-control" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <input type="submit" value="Search" class="btn btn-primary" />
        </div>
    </form>
</div>



<!-- Retain below -->

<p>Records Found: @Html.DisplayFor(model => model.RedIdRecord.Count)</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].FacilityCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].CardNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].ParityBits)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationCity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationState)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationZip)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationLat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].LocationLong)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].UploadedUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].UserID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].IdString)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].RfidRisk)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].CompanyName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0].RFIDContent)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RedIdRecord[0]._partitionKey)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.RedIdRecord)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FacilityCode)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CardNumber)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ParityBits)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationAddress)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationCity)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationState)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationZip)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationLat)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationLong)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UploadedUser)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UserID)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdString)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RfidRisk)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CompanyName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RFIDContent)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item._partitionKey)
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

